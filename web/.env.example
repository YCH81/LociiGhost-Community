# Copy this file to .env.local and fill in the values from your Supabase
# project (Dashboard → Settings → API).
#
# Both keys are SAFE to expose publicly — the anon key is meant to be
# embedded in client-side bundles. RLS policies enforce who can read /
# write what. The service_role key is the one you must NEVER put here.

PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
